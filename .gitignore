# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
sooklabs.env.local
.env.vercel.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# archives and temp extraction (not for version control)
*.zip
_tmp_*/

.vercel
# n8n provision run artifacts (local only)
docs/n8n/hq-provision-result.json
