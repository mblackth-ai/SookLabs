# Copy to sooklabs.env.local (never commit the real file).
# Vercel: add the same keys in Project → Settings → Environment Variables.

RESEND_API_KEY=re_your_key_here
CONTACT_TO_EMAIL=sooklabs.th@gmail.com

# Until sooklabs.com is verified in Resend, omit CONTACT_FROM_EMAIL to use the default sender:
# CONTACT_FROM_EMAIL=SookLabs <onboarding@resend.dev>

# SookLabs HQ (hq.sooklabs.com) — Phase 1 access control.
# HQ_ACCESS_PASSWORD: the single shared password for the HQ login screen.
# HQ_SESSION_SECRET:  a long random string used to HMAC-sign the session cookie.
#                     Generate one, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set both in Vercel → Project → Settings → Environment Variables for production.
HQ_ACCESS_PASSWORD=change-me
HQ_SESSION_SECRET=change-me-to-a-long-random-string
