# Copy to sooklabs.env.local (never commit the real file).
# Vercel: add the same keys in Project → Settings → Environment Variables.

RESEND_API_KEY=re_your_key_here
CONTACT_TO_EMAIL=sooklabs.th@gmail.com

# Until sooklabs.com is verified in Resend, omit CONTACT_FROM_EMAIL to use the default sender:
# CONTACT_FROM_EMAIL=SookLabs <onboarding@resend.dev>

# SookLabs HQ (hq.sooklabs.com) — Phase 1 access control (both required for HQ).
# HQ_ACCESS_PASSWORD: the single shared password for the HQ login screen.
#                     Must not be a placeholder (e.g. "change-me").
# HQ_SESSION_SECRET:  at least 32 characters; HMAC-signs the session cookie.
#                     Generate one, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If either is missing or invalid, HQ login is disabled and protected routes stay locked.
# Set both in Vercel → Project → Settings → Environment Variables for production.
HQ_ACCESS_PASSWORD=change-me
HQ_SESSION_SECRET=change-me-to-a-long-random-string

# SEOS product app URL — used for "Open SEOS app" links from HQ.
# Local: http://localhost:3000
# Production (Vercel Project → Environment Variables): https://seos.sooklabs.com
NEXT_PUBLIC_SEOS_URL=http://localhost:3000
# Optional server-side override for Authority panel fetches
# SEOS_INTERNAL_URL=http://localhost:3000

# HQ ops persistence — DigitalOcean Managed Postgres (required for production on Vercel)
# Without this, UI saves work locally via data/hq/ops.json but WILL NOT persist on Vercel.
# HQ_DATABASE_URL=postgres://user:pass@host:25060/defaultdb?sslmode=require

# HQ automation — morning cron + webhook agents (Ask AI)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# HQ_CRON_SECRET=
# HQ_AGENT_MODE=webhook
# HQ_AGENT_WEBHOOK_URL=https://hooks.sookly.co/webhook/hq-agent
# HQ_AGENT_WEBHOOK_SECRET=   # same value as HQ_AGENT_CALLBACK_SECRET (dispatch auth)
# HQ_AGENT_CALLBACK_SECRET=
# HQ_AGENT_DEFAULT_PROVIDER=cursor
# HQ_N8N_BASE_URL=https://hooks.sookly.co

# ANTHROPIC_API_KEY=   # only if HQ_AGENT_MODE=anthropic
# HQ_LLM_MODEL=claude-sonnet-4-20250514
# HQ_CRON_URL=https://hq.sooklabs.com/hq/api/cron/morning

# SEOS authority oversight (same token value must be set in the SEOS app)
# SEOS_HQ_API_TOKEN=change-me-with-a-long-random-service-token

# Optional public Discord community invite (footer + legal pages)
# NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-invite-code

